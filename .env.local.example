# Supabase project credentials (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-only; NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the app (used to build customer approval links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Instantly for customer notifications and team invite emails.
# Generate API key: Instantly → Settings → Integrations → API (v2).
# INSTANTLY_FROM_EMAIL must be an email account connected in your Instantly workspace.
INSTANTLY_API_KEY=
INSTANTLY_FROM_EMAIL=orders@yourdomain.com

# Optional: Twilio credentials for sending customer notifications via SMS.
# If unset, SMS links are logged to the server console instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: FedEx Rate API for the client shipping portal (/shipping/{token}).
# Set FEDEX_SANDBOX=true to use https://apis-sandbox.fedex.com
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
FEDEX_ACCOUNT_NUMBER=
FEDEX_SANDBOX=true
FEDEX_SHIPPER_STREET=306 Boyd St
FEDEX_SHIPPER_CITY=Los Angeles
FEDEX_SHIPPER_STATE=CA
FEDEX_SHIPPER_ZIP=90013
FEDEX_SHIPPER_COUNTRY=US

# Optional: Stripe for paid delivery on the shipping portal (or configure per-tenant in Settings → Shipping)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Curri same-day courier rates on the client shipping portal.
# Shown alongside FedEx when Settings → Shipping → Curri rates is enabled.
# Auth is Basic base64(CURRI_USER_ID:apiKey). Quotes expire in ~15 minutes.
CURRI_USER_ID=
CURRI_API_KEY=
CURRI_SANDBOX_KEY=
CURRI_SANDBOX=true

# Google Drive folder automation is configured in the app:
# Settings → GDrive (service account JSON, Shared Drive / root folder ID).
# Requires migration 0049_gdrive_settings.sql.
