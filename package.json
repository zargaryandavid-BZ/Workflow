{
  "name": "print-production-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'for p in 3000 3001; do lsof -ti tcp:$p | xargs kill -9 2>/dev/null || true; done; sleep 1; exec env -u TWILIO_ACCOUNT_SID -u TWILIO_AUTH_TOKEN -u TWILIO_PHONE_NUMBER next dev'",
    "dev:clean": "npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "resequence-positions": "npx tsx scripts/resequence-positions.ts",
    "merge-duplicate-customers": "npx tsx scripts/merge-duplicate-customers.ts",
    "clean-orders-customers": "npx tsx scripts/clean-orders-customers.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/react-query": "^5.90.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "next": "^16.2.7",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.2.7",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2"
  }
}
